{
  "extends": [
    "airbnb",
    "airbnb/hooks",
    "prettier"
  ],
  "rules": {
    "default-param-last": 0,
    "react/function-component-definition": [
      2,
      {
        "namedComponents": "arrow-function"
      }
    ],
    "react/require-default-props": 0
  },
  "overrides": [
    {
      "files": [
        "tests/**/*"
      ],
      "plugins": [
        "jest"
      ],
      "env": {
        "jest/globals": true
      }
    }
  ]
}